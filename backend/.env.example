PORT=3001

# --- LLM local (dev uniquement) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=generateur-cr

# --- Services hébergés ---
ANTHROPIC_API_KEY=sk-ant-...
ASSEMBLYAI_API_KEY=

# --- Modes actifs ---
# local = dépend de la machine | hosted = service externe
TRANSCRIPTION_MODE=local
REPORT_MODE=local
STORAGE_MODE=local

# --- Supabase (requis si STORAGE_MODE=hosted) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS (production) ---
# Mettre l'URL Vercel en production, ex: https://mon-app.vercel.app
FRONTEND_URL=http://localhost:5173
